# Normalize text files to LF in the blob, regardless of platform or
# per-user core.autocrlf setting. Without this, sandboxes / containers
# without autocrlf can commit CRLF blobs, which makes every line of every
# touched file appear as "changed" in diffs.
#
# We deliberately do NOT set eol=lf on text files. Setting eol=lf forces
# the working tree to LF as well, which fights Windows core.autocrlf=true
# and emits a warning on every commit for files that are still CRLF in
# the working tree. "text" alone is enough: blob is LF-normalized on
# commit, Windows users with autocrlf=true still get CRLF in their
# working tree, Linux users get LF.
#
# .sh files are the exception — they must stay LF even in a Windows
# working tree, otherwise they break when run through git-bash / WSL.

* text=auto

# Explicit overrides for common text formats (belt and suspenders:
# makes sure text detection never misfires).
*.py    text
*.pyi   text
*.lua   text
*.toml  text
*.yaml  text
*.yml   text
*.md    text
*.txt   text
*.json  text
*.ts    text
*.tsx   text
*.js    text
*.jsx   text
*.html  text
*.css   text

# Shell scripts must be LF even on Windows (run via git-bash / WSL).
*.sh    text eol=lf

# Windows-only files must keep CRLF.
*.bat   text eol=crlf
*.ps1   text eol=crlf
*.ahk   text eol=crlf

# Binary assets — never touch line endings.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.nes   binary
*.sfc   binary
*.smc   binary
*.bps   binary
*.ips   binary
*.mss   binary
*.spinrec binary
