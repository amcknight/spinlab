# checkpoint_cold_spawn.poke — Enter, hit midway checkpoint, die, cold respawn
# Expects: level_entrance, checkpoint(cp_ordinal=1), death, spawn(is_cold_cp=true)
settle: 60

# Baseline
0: level_start=0 exit_mode=0 fanfare=0 player_anim=0 io_port=0 midway=0
# Level context
1: game_mode=20 level_num=105 room_num=1
# Entrance
2: level_start=1
# Checkpoint (midway 0→1)
10: midway=1
# Death
20: player_anim=9
# Clear for respawn
30: player_anim=0 level_start=0 midway=0
# Cold respawn
31: level_start=1
