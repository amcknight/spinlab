# entrance_death_spawn.poke — Enter level, die, respawn
# Expects: level_entrance, death, spawn
settle: 60

# Baseline
0: level_start=0 exit_mode=0 fanfare=0 player_anim=0 io_port=0 midway=0
# Level context
1: game_mode=20 level_num=105 room_num=1
# Entrance
2: level_start=1
# Death (player_anim 0→9)
15: player_anim=9
# Clear for respawn
25: player_anim=0 level_start=0
# Respawn (level_start 0→1 while died_flag is set)
26: level_start=1
