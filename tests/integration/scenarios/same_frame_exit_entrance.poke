# same_frame_exit_entrance.poke — Exit and entrance trigger on same frame
# Tests the ordering guard: exit_mode and level_start both 0→1 simultaneously.
# Expects: first entrance + first exit fire, second entrance (same frame as second exit) is suppressed
settle: 60

# Baseline
0: level_start=0 exit_mode=0 fanfare=0 player_anim=0 io_port=0 midway=0
# Level context
1: game_mode=20 level_num=105 room_num=1
# First entrance
2: level_start=1
# First exit (normal goal)
15: exit_mode=1 fanfare=1 level_start=0
# Clear exit for second transition
16: exit_mode=0 level_start=0
# Second exit + entrance on SAME frame (entrance should be suppressed)
20: exit_mode=1 level_start=1
